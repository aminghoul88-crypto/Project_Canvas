<body>

<header>🎨 DrawApp - Application de Dessin Avancée</header>

<div class="container">

    <!-- SIDEBAR avec outils -->
    <div class="sidebar">
        <div class="tool active" id="brushBtn" title="Pinceau">✏️</div>
        <div class="tool" id="eraserBtn" title="Gomme">🧽</div>
        <div class="tool" id="undoBtn" title="Annuler">↩</div>
        <div class="tool" id="redoBtn" title="Rétablir">↪</div>
        <div class="tool" id="clearBtn" title="Effacer tout">🗑</div>
    </div>

    <div class="canvas-container">
        <canvas id="canvas"></canvas>
    </div>
</div>

<div class="footer">

    <div class="colors" id="colors"></div>

    <div class="controls">
        Taille :
        <input type="range" id="size" min="1" max="50" value="5">
        <span id="sizeLabel">5px</span>
    </div>

    <div class="actions">
        <button class="clear" onclick="clearCanvas()">🆕 Nouveau</button>
    </div>

</div>

<script>
const canvas = document.getElementById("canvas");
const ctx = canvas.getContext("2d");

function resizeCanvas() {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
}
resizeCanvas();
window.addEventListener("resize", resizeCanvas);

let drawing = false;
let tool = "brush";
let color = "#000000";
let size = 5;

ctx.lineCap = "round";
ctx.lineJoin = "round";

// Palette
const palette = ["#000","#e74c3c","#1abc9c","#9b59b6","#2ecc71","#f39c12","#3498db","#e84393"];
const colorContainer = document.getElementById("colors");
let activeColorEl = null;

palette.forEach(c => {
    const div = document.createElement("div");
    div.className = "color";
    div.style.background = c;
    div.onclick = () => {
        color = c;
        if (activeColorEl) activeColorEl.classList.remove("active");
        div.classList.add("active");
        activeColorEl = div;
    };
    colorContainer.appendChild(div);
    if (c === "#000") { div.classList.add("active"); activeColorEl = div; }
});

// Taille
const sizeInput = document.getElementById("size");
const sizeLabel = document.getElementById("sizeLabel");
sizeInput.oninput = () => {
    size = sizeInput.value;
    sizeLabel.textContent = size + "px";
};

// Dessin
function start(x, y) {
    drawing = true;
    ctx.beginPath();
    ctx.moveTo(x, y);
}

function draw(x, y) {
    if (!drawing) return;
    ctx.lineWidth = size;
    ctx.strokeStyle = tool === "eraser" ? "#ffffff" : color;
    ctx.lineTo(x, y);
    ctx.stroke();
}

function stop() {
    if (drawing) saveState();
    drawing = false;
}

// Souris
canvas.addEventListener("mousedown", e => start(e.offsetX, e.offsetY));
canvas.addEventListener("mousemove", e => draw(e.offsetX, e.offsetY));
canvas.addEventListener("mouseup", stop);
canvas.addEventListener("mouseleave", stop);

// Touch mobile
canvas.addEventListener("touchstart", e => {
    e.preventDefault();
    const r = canvas.getBoundingClientRect();
    const t = e.touches[0];
    start(t.clientX - r.left, t.clientY - r.top);
});
canvas.addEventListener("touchmove", e => {
    e.preventDefault();
    const r = canvas.getBoundingClientRect();
    const t = e.touches[0];
    draw(t.clientX - r.left, t.clientY - r.top);
});
canvas.addEventListener("touchend", stop);

// Outils
function setTool(t) {
    tool = t;
    document.querySelectorAll(".tool").forEach(b => b.classList.remove("active"));
    if (t === "brush") document.getElementById("brushBtn").classList.add("active");
    else document.getElementById("eraserBtn").classList.add("active");
}

document.getElementById("brushBtn").onclick = () => setTool("brush");
document.getElementById("eraserBtn").onclick = () => setTool("eraser");

// Historique undo/redo
let history = [];
let step = -1;

function saveState() {
    step++;
    history = history.slice(0, step);
    history.push(canvas.toDataURL());
}

function undo() {
    if (step > 0) { step--; restore(); }
}

function redo() {
    if (step < history.length - 1) { step++; restore(); }
}

function restore() {
    let img = new Image();
    img.src = history[step];
    img.onload = () => ctx.drawImage(img, 0, 0);
}

document.getElementById("undoBtn").onclick = undo;
document.getElementById("redoBtn").onclick = redo;
document.getElementById("clearBtn").onclick = clearCanvas;

function clearCanvas() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    saveState();
}

// Init
saveState();
</script>
</body>
</html>
