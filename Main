<body>

<header>🎨 DrawApp - Application de Dessin</header>

<div class="container">
    <div class="canvas-container">
        <canvas id="canvas"></canvas>
    </div>
</div>

<div class="footer">

    <!-- Palette -->
    <div class="colors" id="colors"></div>

    <!-- Taille du pinceau -->
    <div class="controls">
        Taille :
        <input type="range" id="size" min="1" max="50" value="5">
        <span id="sizeLabel">5px</span>
    </div>

    <!-- Actions -->
    <button onclick="clearCanvas()">🆕 Nouveau</button>

</div>

<script>
const canvas = document.getElementById("canvas");
const ctx = canvas.getContext("2d");

function resizeCanvas() {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
}
resizeCanvas();
window.addEventListener("resize", resizeCanvas);

let drawing = false;
let color = "#000000";
let size = 5;

ctx.lineCap = "round";
ctx.lineJoin = "round";

// Palette de couleurs
const palette = ["#000","#e74c3c","#1abc9c","#9b59b6","#2ecc71","#f39c12","#3498db","#e84393"];
const colorContainer = document.getElementById("colors");
let activeColorEl = null;

palette.forEach(c => {
    const div = document.createElement("div");
    div.className = "color";
    div.style.background = c;
    div.onclick = () => {
        color = c;
        if (activeColorEl) activeColorEl.classList.remove("active");
        div.classList.add("active");
        activeColorEl = div;
    };
    colorContainer.appendChild(div);
    // Sélectionner le premier par défaut
    if (c === "#000") { div.classList.add("active"); activeColorEl = div; }
});

// Taille du pinceau
const sizeInput = document.getElementById("size");
const sizeLabel = document.getElementById("sizeLabel");
sizeInput.oninput = () => {
    size = sizeInput.value;
    sizeLabel.textContent = size + "px";
};

// Dessin
function start(x, y) {
    drawing = true;
    ctx.beginPath();
    ctx.moveTo(x, y);
}

function draw(x, y) {
    if (!drawing) return;
    ctx.lineWidth = size;
    ctx.strokeStyle = color;
    ctx.lineTo(x, y);
    ctx.stroke();
}

function stop() { drawing = false; }

canvas.addEventListener("mousedown", e => start(e.offsetX, e.offsetY));
canvas.addEventListener("mousemove", e => draw(e.offsetX, e.offsetY));
canvas.addEventListener("mouseup", stop);
canvas.addEventListener("mouseleave", stop);

function clearCanvas() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
}
</script>
</body>
